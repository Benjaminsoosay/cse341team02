{
  "swagger": "2.0",
  "info": {
    "title": "Final Project API - Contacts Management System",
    "description": "A comprehensive REST API for managing contacts, users, events, and RSVPs with Google OAuth authentication, validation, and error handling. Features include full CRUD operations, data validation, and unit testing.",
    "version": "1.0.0",
    "contact": {
      "name": "CSE341 Team 02",
      "email": "team02@example.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "host": "cse341team02.onrender.com",
  "basePath": "/",
  "schemes": ["https", "http"],
  "securityDefinitions": {
    "google-oauth": {
      "type": "oauth2",
      "description": "Google OAuth 2.0 authentication for API access",
      "flow": "accessCode",
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "scopes": {
        "profile": "View your profile information",
        "email": "View your email address",
        "openid": "Authenticate with Google"
      }
    }
  },
  "security": [
    {
      "google-oauth": ["openid", "profile", "email"]
    }
  ],
  "paths": {
    "/api-docs": {
      "get": {
        "summary": "Swagger documentation UI",
        "description": "Interactive API documentation interface",
        "produces": ["text/html"],
        "responses": {
          "200": {
            "description": "Swagger UI interface loaded successfully"
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "API home/welcome endpoint",
        "description": "Returns welcome message and available API endpoints",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Welcome message and API information",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Final Project API - Welcome to the Contacts Management System"
                },
                "documentation": {
                  "type": "string",
                  "example": "/api-docs"
                },
                "endpoints": {
                  "type": "object",
                  "properties": {
                    "contacts": {"type": "string", "example": "/contacts"},
                    "users": {"type": "string", "example": "/users"},
                    "events": {"type": "string", "example": "/events"},
                    "rsvps": {"type": "string", "example": "/rsvps"}
                  }
                },
                "version": {"type": "string", "example": "1.0.0"}
              }
            }
          }
        }
      }
    },
    "/auth/google": {
      "get": {
        "summary": "Google OAuth login",
        "description": "Authenticate using Google OAuth 2.0",
        "produces": ["application/json"],
        "responses": {
          "302": {
            "description": "Redirect to Google login page"
          },
          "500": {
            "description": "Authentication error"
          }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "summary": "Google OAuth callback",
        "description": "Callback endpoint for Google OAuth authentication",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Authentication successful",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string"},
                "user": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "name": {"type": "string"},
                    "email": {"type": "string"}
                  }
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/auth/status": {
      "get": {
        "summary": "Check authentication status",
        "description": "Returns current user authentication status",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Authentication status",
            "schema": {
              "type": "object",
              "properties": {
                "authenticated": {"type": "boolean"},
                "user": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "name": {"type": "string"},
                    "email": {"type": "string"},
                    "role": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Logout user",
        "description": "Ends the current user session",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Successfully logged out",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string"}
              }
            }
          },
          "500": {
            "description": "Error logging out"
          }
        }
      }
    },
    "/contacts": {
      "get": {
        "summary": "Get all contacts",
        "description": "Retrieves a list of all contacts with optional pagination",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "description": "Limit number of contacts returned",
            "minimum": 1,
            "maximum": 100,
            "default": 10
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "description": "Page number for pagination",
            "minimum": 1,
            "default": 1
          }
        ],
        "responses": {
          "200": {
            "description": "List of contacts retrieved successfully",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Contact"
              }
            }
          },
          "401": {
            "description": "Unauthorized - Authentication required"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "post": {
        "summary": "Create a new contact",
        "description": "Creates a new contact with validation. All required fields must be provided.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ContactInput"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact created successfully",
            "schema": {
              "$ref": "#/definitions/Contact"
            }
          },
          "400": {
            "description": "Bad request - Invalid data format"
          },
          "401": {
            "description": "Unauthorized - Authentication required"
          },
          "412": {
            "description": "Validation failed - Missing or invalid required fields"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "summary": "Get a single contact",
        "description": "Retrieves a contact by their unique ID",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Contact ID (MongoDB ObjectId format)"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact retrieved successfully",
            "schema": {
              "$ref": "#/definitions/Contact"
            }
          },
          "400": {
            "description": "Invalid ID format - ID must be a valid MongoDB ObjectId"
          },
          "401": {
            "description": "Unauthorized - Authentication required"
          },
          "404": {
            "description": "Contact not found"
          }
        }
      },
      "put": {
        "summary": "Update a contact",
        "description": "Updates an existing contact by ID. All fields are optional for update.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Contact ID (MongoDB ObjectId format)"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ContactUpdate"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact updated successfully",
            "schema": {
              "$ref": "#/definitions/Contact"
            }
          },
          "400": {
            "description": "Invalid ID format or invalid data"
          },
          "401": {
            "description": "Unauthorized - Authentication required"
          },
          "404": {
            "description": "Contact not found"
          },
          "412": {
            "description": "Validation failed - Invalid field values"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "delete": {
        "summary": "Delete a contact",
        "description": "Permanently deletes a contact by ID",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Contact ID (MongoDB ObjectId format)"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact deleted successfully",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string", "example": "Contact deleted successfully"},
                "deletedCount": {"type": "integer", "example": 1}
              }
            }
          },
          "400": {
            "description": "Invalid ID format"
          },
          "401": {
            "description": "Unauthorized - Authentication required"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
