              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Rsvp"
                }
              }
            }
          },
          "404": {
            "description": "RSVP not found"
          }
        }
      },
      "put": {
        "summary": "Update an RSVP (requires GitHub authentication)",
        "tags": ["RSVPs"],
        "security": [
          {
            "sessionAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["yes", "no", "maybe"]
                  }
                }
              }
