{
  "swagger": "2.0",
  "info": {
    "title": "Final Project API - Contacts Management System",
    "description": "A comprehensive REST API for managing contacts, users, events, and RSVPs with Google OAuth authentication, validation, and error handling. Features include full CRUD operations, data validation, and unit testing.\n\n**Authentication Note:** To authenticate, DO NOT use the 'Try it out' button below. Instead, open a new browser tab and visit:\nhttps://cse341team02.onrender.com/auth/google\n\nAfter logging in, copy the access_token from the response and use it in the Authorize button above.",
    "version": "1.0.0",
    "contact": {
      "name": "CSE341 Team 02",
      "email": "team02@example.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "host": "cse341team02.onrender.com",
  "basePath": "/",
  "schemes": ["https", "http"],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "Enter your Bearer token as: Bearer YOUR_ACCESS_TOKEN\n\nTo get a token: 1) Visit /auth/google in your browser, 2) Login with Google, 3) Copy the access_token from the response"
    },
    "google-oauth": {
      "type": "oauth2",
      "description": "Google OAuth 2.0 authentication (Note: Use browser tab, not Swagger UI)",
      "flow": "accessCode",
      "authorizationUrl": "https://accounts.google.com/o/oauth2/v2/auth",
      "tokenUrl": "https://oauth2.googleapis.com/token",
      "scopes": {
        "profile": "View your profile information",
        "email": "View your email address",
        "openid": "Authenticate with Google"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api-docs": {
      "get": {
        "summary": "Swagger documentation UI",
        "description": "Interactive API documentation interface",
        "produces": ["text/html"],
        "responses": {
          "200": {
            "description": "Swagger UI interface loaded successfully"
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "API home/welcome endpoint",
        "description": "Returns welcome message and available API endpoints",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Welcome message and API information",
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "example": "Final Project API - Welcome to the Contacts Management System"
                },
                "documentation": {
                  "type": "string",
                  "example": "/api-docs"
                },
                "swaggerJson": {
                  "type": "string",
                  "example": "/swagger.json"
                },
                "endpoints": {
                  "type": "object",
                  "properties": {
                    "contacts": {"type": "string", "example": "/contacts"},
                    "users": {"type": "string", "example": "/users"},
                    "events": {"type": "string", "example": "/events"},
                    "rsvps": {"type": "string", "example": "/rsvps"}
                  }
                },
                "auth": {
                  "type": "object",
                  "properties": {
                    "google_login": {"type": "string", "example": "/auth/google"},
                    "auth_status": {"type": "string", "example": "/auth/status"},
                    "logout": {"type": "string", "example": "/auth/logout"}
                  }
                },
                "version": {"type": "string", "example": "1.0.0"}
              }
            }
          }
        }
      }
    },
    "/auth/google": {
      "get": {
        "summary": "Google OAuth login - OPEN IN BROWSER TAB",
        "description": "⚠️ IMPORTANT: Do not use 'Try it out' in Swagger UI. This endpoint redirects to Google and Swagger UI cannot handle redirects.\n\n✅ CORRECT USAGE:\n1. Open a new browser tab\n2. Go to: https://cse341team02.onrender.com/auth/google\n3. Log in with your Google account\n4. Copy the access_token from the JSON response\n5. Click the 'Authorize' button above and paste: Bearer YOUR_TOKEN\n\nThis endpoint returns a JSON response with access_token, user info, and refresh_token.",
        "produces": ["application/json"],
        "responses": {
          "302": {
            "description": "Redirect to Google login page (when accessed directly in browser)"
          },
          "200": {
            "description": "Authentication successful - Returns access_token and user info",
            "schema": {
              "type": "object",
              "properties": {
                "success": {"type": "boolean", "example": true},
                "access_token": {"type": "string", "example": "ya29.xxx"},
                "refresh_token": {"type": "string", "example": "1//xxx"},
                "expires_in": {"type": "integer", "example": 3599},
                "user": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "email": {"type": "string"},
                    "name": {"type": "string"},
                    "avatar": {"type": "string"},
                    "role": {"type": "string"}
                  }
                }
              }
            }
          },
          "500": {
            "description": "Authentication error"
          }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "summary": "Google OAuth callback (internal)",
        "description": "Internal callback endpoint for Google OAuth. This endpoint should not be called directly.",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Authentication successful"
          },
          "400": {
            "description": "No authorization code provided"
          },
          "500": {
            "description": "Authentication failed"
          }
        }
      }
    },
    "/auth/status": {
      "get": {
        "summary": "Check authentication status",
        "description": "Returns current user authentication status from session",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Authentication status",
            "schema": {
              "type": "object",
              "properties": {
                "authenticated": {"type": "boolean"},
                "user": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "name": {"type": "string"},
                    "email": {"type": "string"},
                    "role": {"type": "string"}
                  }
                },
                "access_token": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Logout user",
        "description": "Ends the current user session",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Successfully logged out",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string", "example": "Logged out successfully"}
              }
            }
          },
          "500": {
            "description": "Error logging out"
          }
        }
      }
    },
    "/users/profile": {
      "get": {
        "summary": "Get current user profile",
        "description": "Returns the profile of the authenticated user. Requires Bearer token.",
        "produces": ["application/json"],
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "User profile retrieved successfully",
            "schema": {
              "$ref": "#/definitions/User"
            }
          },
          "401": {
            "description": "Unauthorized - Invalid or missing token"
          }
        }
      }
    },
    "/contacts": {
      "get": {
        "summary": "Get all contacts",
        "description": "Retrieves a list of all contacts with optional pagination. No authentication required.",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "type": "integer",
            "description": "Limit number of contacts returned (0 for unlimited)",
            "minimum": 0,
            "maximum": 100,
            "default": 10
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "type": "integer",
            "description": "Page number for pagination",
            "minimum": 1,
            "default": 1
          }
        ],
        "responses": {
          "200": {
            "description": "List of contacts retrieved successfully",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Contact"
              }
            }
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "post": {
        "summary": "Create a new contact",
        "description": "Creates a new contact with validation. All required fields must be provided. No authentication required.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ContactInput"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Contact created successfully",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string", "example": "Contact created successfully"},
                "id": {"type": "string", "example": "507f1f77bcf86cd799439011"}
              }
            }
          },
          "400": {
            "description": "Bad request - Invalid data format"
          },
          "412": {
            "description": "Validation failed - Missing or invalid required fields"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/contacts/{id}": {
      "get": {
        "summary": "Get a single contact",
        "description": "Retrieves a contact by their unique ID. No authentication required.",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Contact ID (MongoDB ObjectId format)"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact retrieved successfully",
            "schema": {
              "$ref": "#/definitions/Contact"
            }
          },
          "400": {
            "description": "Invalid ID format"
          },
          "404": {
            "description": "Contact not found"
          }
        }
      },
      "put": {
        "summary": "Update a contact",
        "description": "Updates an existing contact by ID. All fields are optional for update. No authentication required.",
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Contact ID (MongoDB ObjectId format)"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ContactUpdate"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Contact updated successfully",
            "schema": {
              "$ref": "#/definitions/Contact"
            }
          },
          "400": {
            "description": "Invalid ID format or invalid data"
          },
          "404": {
            "description": "Contact not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "delete": {
        "summary": "Delete a contact",
        "description": "Permanently deletes a contact by ID. No authentication required.",
        "produces": ["application/json"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "Contact ID (MongoDB ObjectId format)"
          }
        ],
        "responses": {
          "200": {
            "description": "Contact deleted successfully",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string", "example": "Contact deleted successfully"}
              }
            }
          },
          "400": {
            "description": "Invalid ID format"
          },
          "404": {
            "description": "Contact not found"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Get all users (Admin only)",
        "description": "Retrieves a list of all registered users. Requires admin role and Bearer token.\n\nTo get admin access: Update your role in MongoDB Atlas from 'user' to 'admin'.",
        "produces": ["application/json"],
        "security": [{"bearerAuth": []}],
        "responses": {
          "200": {
            "description": "List of users retrieved successfully",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/User"
              }
            }
          },
          "401": {
            "description": "Unauthorized - No token provided"
          },
          "403": {
            "description": "Forbidden - Admin role required"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/public-users": {
      "get": {
        "summary": "Get all users (Public - Development only)",
        "description": "Temporary public endpoint to view users. No authentication required.",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "List of users retrieved successfully",
            "schema": {
              "type": "object",
              "properties": {
                "count": {"type": "integer"},
                "users": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string"},
                      "name": {"type": "string"},
                      "email": {"type": "string"},
                      "role": {"type": "string"}
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/test-db": {
      "get": {
        "summary": "Test database connection",
        "description": "Returns database connection status and collections",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Database connected successfully",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string"},
                "collections": {"type": "array", "items": {"type": "string"}},
                "dbName": {"type": "string"},
                "status": {"type": "string"}
              }
            }
          },
          "500": {
            "description": "Database connection error"
          }
        }
      }
    },
    "/login": {
      "get": {
        "summary": "Login page info",
        "description": "Provides information about OAuth authentication",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Login information",
            "schema": {
              "type": "object",
              "properties": {
                "message": {"type": "string"},
                "note": {"type": "string"},
                "oauth_endpoints": {
                  "type": "object",
                  "properties": {
                    "google": {"type": "string", "example": "/auth/google"},
                    "status": {"type": "string", "example": "/auth/status"}
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "Contact": {
      "type": "object",
      "properties": {
        "_id": {"type": "string"},
        "firstName": {"type": "string"},
        "lastName": {"type": "string"},
        "email": {"type": "string"},
        "favoriteColor": {"type": "string"},
        "birthday": {"type": "string", "format": "date"},
        "phoneNumber": {"type": "string"},
        "address": {"type": "string"},
        "createdAt": {"type": "string", "format": "date-time"},
        "updatedAt": {"type": "string", "format": "date-time"}
      }
    },
    "ContactInput": {
      "type": "object",
      "required": ["firstName", "lastName", "email", "favoriteColor"],
      "properties": {
        "firstName": {"type": "string", "minLength": 1, "maxLength": 50},
        "lastName": {"type": "string", "minLength": 1, "maxLength": 50},
        "email": {"type": "string", "format": "email"},
        "favoriteColor": {"type": "string"},
        "birthday": {"type": "string", "format": "date"},
        "phoneNumber": {"type": "string"},
        "address": {"type": "string", "maxLength": 200}
      }
    },
    "ContactUpdate": {
      "type": "object",
      "properties": {
        "firstName": {"type": "string"},
        "lastName": {"type": "string"},
        "email": {"type": "string", "format": "email"},
        "favoriteColor": {"type": "string"},
        "birthday": {"type": "string", "format": "date"},
        "phoneNumber": {"type": "string"},
        "address": {"type": "string"}
      }
    },
    "User": {
      "type": "object",
      "properties": {
        "_id": {"type": "string"},
        "email": {"type": "string"},
        "name": {"type": "string"},
        "avatar": {"type": "string"},
        "role": {"type": "string", "enum": ["user", "admin"]},
        "createdAt": {"type": "string", "format": "date-time"},
        "lastLogin": {"type": "string", "format": "date-time"}
      }
    }
  },
  "tags": [
    {
      "name": "Contacts",
      "description": "Contact management operations (Public - No auth required)"
    },
    {
      "name": "Users",
      "description": "User management (Requires authentication & admin role)"
    },
    {
      "name": "Authentication",
      "description": "Google OAuth authentication endpoints"
    }
  ]
}
